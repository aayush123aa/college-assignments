/*
define a structure book with:
title
author
price
number of copies

write functions to:

print books by a given author
print books with price less than a given value
print total cost of a book (price*copies)

*/

#include<stdio.h>
#include<string.h>

struct book
{
	char title[50],author[50];
	int price,nc;
}n[4];

void writer(char author[]);
void price(int m);
void cost(char book[]);

void main()
{
	int i,max_p;
	char author[50],book[50];
	
	printf("input the details of the book:\n");
	for(i=0;i<4;i++)
	{
		printf("title:\t"); scanf("%s",&n[i].title);
		printf("author:\t"); scanf("%s",&n[i].author);
		printf("price:\t"); scanf("%d",&n[i].price);
		printf("no. of copies:\t"); scanf("%d",&n[i].nc);
	}
	
	printf("\nwhat author's book do you wish me to fetch ?  ");	scanf("%s",author);
	writer(author);
	printf("\nwhat is the maximum price for you ?  ");	scanf("%d",&max_p);
	price(max_p);
	printf("\nwhat book's total cost do you want me to calculate ?  ");	scanf("%s",book);
	cost(book);
	
	
}

void price(int m)
{
	int i;
	for(i=0;i<4;i++)
	{
		if(n[i].price<m)
		{
			printf("\nname: %s and price: %d\n",n[i].title,n[i].price);
		}
	}
}

void writer(char author[])
{
	int i;
	for(i=0;i<4;i++)
	{
		if(strcmp(author,n[i].author)==0)
		{
			printf("\nbook name: %s\n",n[i].title);
		}
	}
	
}

void cost(char book[])
{
	int i, price=0;
	for(i=0;i<4;i++)
	{
		if(strcmp(book,n[i].title)==0)
		{
			price=n[i].nc*n[i].price;
		}
	}
	
	printf("\nthe total cost of the book %s is: %d\n",book,price);
}
